generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id                  Int       @id @default(autoincrement())
  name                String
  publishedVersionId  Int?      @unique
  publishedVersion    Version?  @relation("PublishedVersion", fields: [publishedVersionId], references: [id])
  versions            Version[] @relation("DocumentVersions")
  routes              Route[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  archivedAt          DateTime?
  folderId            Int?
  folder              Folder?   @relation("FolderDocuments", fields: [folderId], references: [id])
}

model Version {
  id                  Int       @id @default(autoincrement())
  documentId          Int
  document            Document  @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  publishedDocumentOf Document? @relation("PublishedVersion")
  content             Json
  createdAt           DateTime  @default(now())
}

model Media {
  id          Int      @id @default(autoincrement())
  name        String
  storagePath String   @unique
  size        Int
  contentType String?
  createdAt   DateTime @default(now())
  folderId    Int?
  folder      Folder?  @relation("FolderMedia", fields: [folderId], references: [id])
}

model Route {
  id          Int       @id @default(autoincrement())
  path        String    @unique
  documentId  Int
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Folder {
  id         Int        @id @default(autoincrement())
  name       String
  parentId   Int?
  parent     Folder?    @relation("FolderNesting", fields: [parentId], references: [id])
  children   Folder[]   @relation("FolderNesting")
  documents  Document[] @relation("FolderDocuments")
  media      Media[]    @relation("FolderMedia")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}